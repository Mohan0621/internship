{
  "name": "mohan-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend authentication using Better Auth and Prisma",
  "main": "backend/server.ts",
  "scripts": {
    "dev": "tsx watch backend/server.ts",
    "build": "tsc",
    "start": "node backend/server.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage"
  },
  "vitest": {
    "environment": "node",
    "globals": true
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "better-auth": "^1.6.16",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  }
}